            'what is 10*10': '10 × 10 = 100. 🧮',
            'what is the square root of 144': 'The square root of 144 is 12. 🧮',
            'what is the meaning of life': 'The meaning of life is a philosophical question. Many believe it\'s about finding purpose, connection, and happiness. 🌟',
            'tell me a joke': 'Why do programmers prefer dark mode? Because light attracts bugs! 😄',
            'help': 'I can help with programming, math, science, history, writing, coding, and general knowledge. Just ask me anything!',
        };

        // ============================================================
        //  DOM REFS
        // ============================================================

        const searchInput = document.getElementById('searchInput');
        const suggestionsEl = document.getElementById('suggestions');
        const aiAnswer = document.getElementById('aiAnswer');
        const aiContent = document.getElementById('aiContent');
        const voiceBtn = document.getElementById('voiceBtn');
        const aiBtn = document.getElementById('aiBtn');
        const quickIconsEl = document.getElementById('quickIcons');
        const themeIcon = document.getElementById('themeIcon');

        // ============================================================
        //  THEME
        // ============================================================

        let isDark = localStorage.getItem('theme') === 'dark';

        function applyTheme() {
            document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
            themeIcon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
        }

        function toggleTheme() {
            isDark = !isDark;
            applyTheme();
        }

        applyTheme();

        // ============================================================
        //  RENDER QUICK ICONS
        // ============================================================

        function renderQuickIcons() {
            quickIconsEl.innerHTML = QUICK_ICONS.map(item => `
                <a class="quick-icon" href="${item.url}" target="_blank" title="${item.name}">
                    <div class="icon-placeholder">${item.emoji}</div>
                    <span>${item.name}</span>
                    <span class="tooltip">${item.name}</span>
                </a>
            `).join('');
        }
        renderQuickIcons();

        // ============================================================
        //  SUGGESTIONS
        // ============================================================

        function getSuggestions(query) {
            if (!query || query.length < 1) return [];
            const q = query.toLowerCase().trim();
            const keys = Object.keys(OFFICIAL_SITES);
            const matches = keys.filter(k => k.includes(q));
            // Also add some common suggestions
            const extra = [
                'GitHub', 'GitLab', 'Gmail', 'Google', 'Google Maps', 'Google Drive',
                'YouTube', 'Instagram', 'Facebook', 'Twitter', 'LinkedIn', 'Netflix',
                'Amazon', 'Wikipedia', 'ChatGPT', 'Spotify', 'Discord', 'Reddit'
            ];
            const extraMatches = extra.filter(e => e.toLowerCase().includes(q));
            const all = [...new Set([...matches, ...extraMatches])];
            return all.slice(0, 8);
        }

        function showSuggestions(query) {
            const list = getSuggestions(query);
            if (list.length === 0) {
                suggestionsEl.classList.remove('show');
                return;
            }
            suggestionsEl.innerHTML = list.map(item => `
                <li data-value="${item}">
                    <i class="fas fa-globe"></i>
                    <span>${highlightMatch(item, query)}</span>
                </li>
            `).join('');
            suggestionsEl.classList.add('show');

            // Click handler
            suggestionsEl.querySelectorAll('li').forEach(li => {
                li.addEventListener('click', () => {
                    const val = li.dataset.value;
                    searchInput.value = val;
                    suggestionsEl.classList.remove('show');
                    performSearch(val);
                });
            });
        }

        function highlightMatch(text, query) {
            const idx = text.toLowerCase().indexOf(query.toLowerCase());
            if (idx === -1) return text;
            return text.slice(0, idx) +
                `<span class="highlight">${text.slice(idx, idx + query.length)}</span>` +
                text.slice(idx + query.length);
        }

        // ============================================================
        //  SEARCH
        // ============================================================

        function performSearch(query) {
            if (!query || query.trim() === '') return;
            const q = query.trim().toLowerCase();

            // 1. Check official site
            const siteKey = Object.keys(OFFICIAL_SITES).find(k => k === q);
            if (siteKey) {
                window.open(OFFICIAL_SITES[siteKey], '_blank');
                return;
            }

            // 2. Check if it's a known site by partial match (if exactly one)
            const partialMatches = Object.keys(OFFICIAL_SITES).filter(k => k.includes(q));
            if (partialMatches.length === 1) {
                window.open(OFFICIAL_SITES[partialMatches[0]], '_blank');
                return;
            }

            // 3. AI answer
            const aiResponse = getAIResponse(q);
            if (aiResponse) {
                aiContent.innerHTML = aiResponse;
                aiAnswer.classList.add('show');
                // Still show web results in background
                fallbackWebSearch(q);
                return;
            }

            // 4. Fallback: web search
            fallbackWebSearch(q);
        }

        function fallbackWebSearch(query) {
            // Use Google Custom Search or DuckDuckGo as fallback
            // We'll use DuckDuckGo for privacy
            const url = `https://duckduckgo.com/?q=${encodeURIComponent(query)}`;
            window.open(url, '_blank');
        }

        // ============================================================
        //  AI RESPONSE
        // ============================================================

        function getAIResponse(query) {
            const q = query.toLowerCase().trim();
            // Direct match
            for (const [key, value] of Object.entries(AI_KNOWLEDGE)) {
                if (q.includes(key) || key.includes(q)) {
                    return value;
                }
            }
            // Check for math expressions
            if (/^[0-9+\-*/\^(). ]+$/.test(q)) {
                try {
                    const result = Function('"use strict"; return (' + q + ')')();
                    return `🧮 The result of <strong>${q}</strong> is <strong>${result}</strong>.`;
                } catch (e) {
                    return null;
                }
            }
            // Check for weather, time, etc.
            if (q.includes('weather')) {
                return `🌤️ Please check your local weather app or search for "${query}" for the latest forecast.`;
            }
            if (q.includes('time')) {
                return `🕐 The current time is ${new Date().toLocaleTimeString()}.`;
            }
            if (q.includes('date')) {
                return `📅 Today is ${new Date().toLocaleDateString()}.`;
            }
            if (q.includes('translate')) {
                return `🌐 Use Google Translate for translation services.`;
            }
            if (q.includes('dictionary') || q.includes('meaning')) {
                return `📖 Check a dictionary or search for "${query}" for definitions.`;
            }
            return null;
        }

        // ============================================================
        //  VOICE SEARCH
        // ============================================================

        let isRecording = false;
        let recognition = null;

        if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            recognition = new SpeechRecognition();
            recognition.lang = 'en-US';
            recognition.continuous = false;
            recognition.interimResults = false;

            recognition.onresult = (event) => {
                const transcript = event.results[0][0].transcript;
                searchInput.value = transcript;
                voiceBtn.classList.remove('recording');
                isRecording = false;
                performSearch(transcript);
            };

            recognition.onerror = () => {
                voiceBtn.classList.remove('recording');
                isRecording = false;
            };

            recognition.onend = () => {
                voiceBtn.classList.remove('recording');
                isRecording = false;
            };
        }

        voiceBtn.addEventListener('click', () => {
            if (!recognition) {
                alert('Voice search is not supported in this browser. Please use Chrome, Edge, or Safari.');
                return;
            }
            if (isRecording) {
                recognition.stop();
                voiceBtn.classList.remove('recording');
                isRecording = false;
                return;
            }
            recognition.start();
            voiceBtn.classList.add('recording');
            isRecording = true;
        });

        // ============================================================
        //  AI BUTTON
        // ============================================================

        aiBtn.addEventListener('click', () => {
            const query = searchInput.value.trim() || 'help';
            const response = getAIResponse(query);
            if (response) {
                aiContent.innerHTML = response;
                aiAnswer.classList.add('show');
            } else {
                aiContent.innerHTML = `🤔 I couldn't find a specific answer for "<strong>${query}</strong>". Try searching the web!`;
                aiAnswer.classList.add('show');
            }
        });

        // ============================================================
        //  INPUT EVENTS
        // ============================================================

        searchInput.addEventListener('input', (e) => {
            const val = e.target.value;
            if (val.length > 1) {
                showSuggestions(val);
            } else {
                suggestionsEl.classList.remove('show');
            }
            // Hide AI answer when typing
            aiAnswer.classList.remove('show');
        });

        searchInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                const val = searchInput.value.trim();
                suggestionsEl.classList.remove('show');
                if (val) performSearch(val);
            }
            if (e.key === 'Escape') {
                suggestionsEl.classList.remove('show');
                searchInput.blur();
            }
            // Arrow navigation for suggestions
            if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
                const items = suggestionsEl.querySelectorAll('li');
                if (items.length === 0) return;
                e.preventDefault();
                let idx = Array.from(items).findIndex(li => li.classList.contains('selected'));
                if (e.key === 'ArrowDown') {
                    idx = (idx + 1) % items.length;
                } else {
                    idx = (idx - 1 + items.length) % items.length;
                }
                items.forEach(li => li.classList.remove('selected'));
                items[idx].classList.add('selected');
                searchInput.value = items[idx].dataset.value;
            }
        });

        // Click outside to close suggestions
        document.addEventListener('click', (e) => {
            if (!e.target.closest('.search-wrapper')) {
                suggestionsEl.classList.remove('show');
            }
        });

        // ============================================================
        //  CATEGORY CLICKS
        // ============================================================

        document.querySelectorAll('.categories button').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.categories button').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                // Simulate category search
                const cat = btn.textContent;
                searchInput.value = cat + ' ';
                searchInput.focus();
                // Trigger AI answer for category
                const response = getAIResponse(cat);
                if (response) {
                    aiContent.innerHTML = `🔍 <strong>${cat}</strong> category selected. ${response}`;
                    aiAnswer.classList.add('show');
                }
            });
        });

        // ============================================================
        //  TRENDING CLICKS
        // ============================================================

        document.querySelectorAll('.trending-tags span').forEach(tag => {
            tag.addEventListener('click', () => {
                searchInput.value = tag.textContent;
                performSearch(tag.textContent);
            });
        });

        // ============================================================
        //  RESET HOME
        // ============================================================

        function resetHome() {
            searchInput.value = '';
            suggestionsEl.classList.remove('show');
            aiAnswer.classList.remove('show');
            searchInput.focus();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // ============================================================
        //  KEYBOARD SHORTCUTS
        // ============================================================

        document.addEventListener('keydown', (e) => {
            // Ctrl+K or Cmd+K → focus search
            if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
                e.preventDefault();
                searchInput.focus();
                searchInput.select();
            }
            // Escape → clear
            if (e.key === 'Escape' && document.activeElement === searchInput) {
                searchInput.value = '';
                suggestionsEl.classList.remove('show');
                aiAnswer.classList.remove('show');
                searchInput.blur();
            }
        });

        // ============================================================
        //  INIT
        // ============================================================

        // Focus search on load
        setTimeout(() => searchInput.focus(), 300);

        console.log(`✨ ${SITE_NAME} loaded successfully!`);
        console.log('🔍 Type a website name to jump directly, or ask AI for help.');
        console.log('🎤 Use voice search, or click the AI button for intelligent answers.');

