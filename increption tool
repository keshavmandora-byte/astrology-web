<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>Caesar Cipher | Cybersecurity Encryption Tool</title>
  <!-- Google Fonts & Font Awesome -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <!-- Tailwind CSS CDN (lightweight) -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Custom overrides for Tailwind + glassmorphism/neon -->
  <style>
    * {
      font-family: 'Inter', sans-serif;
      transition: all 0.2s ease;
    }
    body {
      background: radial-gradient(circle at 20% 30%, #0a0f1e, #03050b);
      overflow-x: hidden;
    }
    /* Floating binary animation */
    .binary-bg {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }
    .binary-float {
      position: absolute;
      color: rgba(0, 255, 170, 0.08);
      font-family: monospace;
      font-size: 1.2rem;
      user-select: none;
      white-space: nowrap;
      animation: floatBinary 20s linear infinite;
    }
    @keyframes floatBinary {
      0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
      10% { opacity: 0.6; }
      90% { opacity: 0.4; }
      100% { transform: translateY(-20vh) rotate(5deg); opacity: 0; }
    }
    /* Glassmorphism Card */
    .glass-card {
      background: rgba(15, 25, 45, 0.55);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(0, 255, 255, 0.2);
      border-radius: 2rem;
      box-shadow: 0 20px 35px -12px rgba(0,0,0,0.5);
    }
    .neon-text {
      text-shadow: 0 0 6px #0ff, 0 0 12px #0ff;
    }
    .btn-neon {
      background: linear-gradient(95deg, #0a2f44, #0a1a2a);
      border: 1px solid #0ff;
      transition: 0.2s;
    }
    .btn-neon:hover {
      box-shadow: 0 0 12px #0ff;
      transform: scale(1.02);
      border-color: #0f0;
    }
    .alphabet-highlight {
      background: linear-gradient(90deg, #0ff, #2effb0);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    .stat-card {
      background: rgba(0, 20, 30, 0.6);
      border-left: 4px solid #0ff;
    }
    /* scroll animation fade-up */
    .fade-up {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .fade-up.appear {
      opacity: 1;
      transform: translateY(0);
    }
    /* character animation on output */
    @keyframes charPop {
      0% { opacity: 0; transform: scale(0.8);}
      80% { transform: scale(1.05);}
      100% { opacity: 1; transform: scale(1);}
    }
    .char-animate {
      display: inline-block;
      animation: charPop 0.2s ease forwards;
    }
    .dark-mode-toggle {
      cursor: pointer;
    }
    body.dark {
      background: radial-gradient(circle at 20% 30%, #0b1120, #010101);
    }
    /* custom scroll */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #0a1428; border-radius: 10px; }
    ::-webkit-scrollbar-thumb { background: #0ff; border-radius: 10px; }
  </style>
</head>
<body class="text-white relative">

