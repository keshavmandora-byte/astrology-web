    <!-- FAQ Section -->
    <section class="fade-up my-12 glass-card p-6 md:p-8">
      <h2 class="text-2xl font-bold mb-4"><i class="fas fa-question-circle text-cyan-400 mr-2"></i> Frequently Asked Questions</h2>
      <div class="grid md:grid-cols-2 gap-5 text-sm">
        <div><span class="font-bold text-cyan-300">Q: What is Caesar Cipher?</span><br>A: Substitution cipher shifting letters by fixed positions.</div>
        <div><span class="font-bold text-cyan-300">Q: Is Caesar Cipher secure?</span><br>A: No, easily broken by brute force (only 25 keys) or frequency analysis.</div>
        <div><span class="font-bold text-cyan-300">Q: Where is it used?</span><br>A: Educational purposes, puzzles, and as a basis for more complex ciphers.</div>
        <div><span class="font-bold text-cyan-300">Q: Limitations?</span><br>A: Preserves letter frequencies, no security for sensitive data.</div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="glass-card mt-16 p-6 text-center text-gray-300 text-sm">
      <div class="flex justify-center gap-6 text-xl mb-3">
        <a href="#" class="hover:text-cyan-400"><i class="fab fa-github"></i></a>
        <a href="#" class="hover:text-cyan-400"><i class="fab fa-twitter"></i></a>
        <a href="#" class="hover:text-cyan-400"><i class="fab fa-linkedin"></i></a>
      </div>
      <p>📧 caesar-cipher@cyberlab.com | 🔐 Learn. Encrypt. Decrypt.</p>
      <p class="mt-2 text-gray-500">&copy; 2026 Caesar Cipher Tool - Open Source Cybersecurity Education</p>
    </footer>
  </div>

  <!-- Dark/Light mode toggle (floating) -->
  <button id="darkModeToggle" class="fixed bottom-6 right-6 z-50 bg-black/50 backdrop-blur border border-cyan-400 rounded-full p-3 shadow-lg"><i class="fas fa-moon text-cyan-300"></i></button>

  <script>
    // ---------- CAESAR CIPHER CORE ----------
    function caesarEncrypt(text, shift) {
      shift = ((shift % 26) + 26) % 26;
      return text.replace(/[A-Za-z]/g, (ch) => {
        const base = (ch >= 'A' && ch <= 'Z') ? 65 : 97;
        let code = ch.charCodeAt(0);
        let shifted = ((code - base + shift) % 26) + base;
        return String.fromCharCode(shifted);
      });
    }

    function caesarDecrypt(text, shift) {
      return caesarEncrypt(text, (26 - shift) % 26);
    }

    // Helper update stats
    function updateStats(message, shiftVal, statusMsg) {
      let letters = (message.match(/[A-Za-z]/g) || []).length;
      document.getElementById('statChars').innerText = message.length;
      document.getElementById('statLetters').innerText = letters;
      document.getElementById('statShift').innerText = shiftVal;
      document.getElementById('statStatus').innerHTML = statusMsg;
    }

    // update alphabet visualizer
    function updateAlphabetVisual(shift) {
      const alpha = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
      const shifted = alpha.slice(shift) + alpha.slice(0, shift);
      document.getElementById('shiftedAlpha').innerText = shifted;
      document.getElementById('shiftDisplayVal').innerText = shift;
      document.getElementById('visualShiftRow').innerText = shifted;
      let firstLetter = alpha[0];
      let mapped = shifted[0];
      document.getElementById('exampleMap').innerHTML = `${firstLetter} → ${mapped}`;
    }

    // Step-by-step explanation builder
    function buildSteps(original, shift, mode) { // mode 'encrypt' or 'decrypt'
      if (!original.trim()) return "No text to process.";
      let resultText = (mode === 'encrypt') ? caesarEncrypt(original, shift) : caesarDecrypt(original, shift);
      let stepsHtml = `<p class="mb-2 font-bold text-cyan-300">Original: "${original}"<br>Shift: ${shift} (${mode === 'encrypt' ? 'Encryption' : 'Decryption'})</p><div class="grid grid-cols-1 gap-1 text-xs">`;
      let letterIndex = 0;
      for (let char of original) {
        if (/[A-Za-z]/.test(char)) {
          let base = (char >= 'A' && char <= 'Z') ? 65 : 97;
          let origCode = char.charCodeAt(0);
          let outChar = resultText[letterIndex];
          let newCode = outChar.charCodeAt(0);
          let shiftApplied = ((newCode - base + 26) % 26) - ((origCode - base + 26) % 26);
          if (mode === 'decrypt') shiftApplied = -shiftApplied;
          stepsHtml += `<div class="border-b border-gray-700 py-1"><span class="text-green-300">'${char}'</span> → <span class="text-cyan-300">'${outChar}'</span> (shift ${shiftApplied >0 ? '+' : ''}${shiftApplied})</div>`;
        } else {
          let outChar = resultText[letterIndex];
          stepsHtml += `<div class="border-b border-gray-700 py-1 text-gray-400">'${char}' (non-letter) → '${outChar}'</div>`;
        }
        letterIndex++;
      }
      stepsHtml += `</div><p class="mt-2 font-bold text-green-300">Result: "${resultText}"</p>`;
      return stepsHtml;
    }

    // Character animation on output
    function animateOutput(text) {
      const outputDiv = document.getElementById('outputResult');
      outputDiv.innerHTML = '';
      for(let i=0; i<text.length; i++) {
        let span = document.createElement('span');
        span.innerText = text[i];
        span.className = 'char-animate inline-block';
        span.style.animationDelay = `${i * 0.01}s`;
        outputDiv.appendChild(span);
      }
    }

    let currentMode = null; // 'encrypt' or 'decrypt'
    let lastMessage = "";
    let lastShift = 3;

    function refreshToolBasedOnMode() {
      let msg = document.getElementById('messageInput').value;
      let shift = parseInt(document.getElementById('shiftValue').value) || 0;
      if (shift < 1) shift = 1;
      if (shift > 25) shift = 25;
      document.getElementById('shiftValue').value = shift;
      updateAlphabetVisual(shift);
      if (msg === "") {
        document.getElementById('outputResult').innerHTML = "Enter message above...";
        document.getElementById('stepByStepArea').innerHTML = "Waiting for input.";
        updateStats(msg, shift, "Idle");
        return;
      }
      let output = "";
      let stepDesc = "";
      if (currentMode === 'encrypt') {
        output = caesarEncrypt(msg, shift);
        stepDesc = buildSteps(msg, shift, 'encrypt');
        updateStats(msg, shift, "Encrypted");
      } else if (currentMode === 'decrypt') {
        output = caesarDecrypt(msg, shift);
        stepDesc = buildSteps(msg, shift, 'decrypt');
        updateStats(msg, shift, "Decrypted");
      } else {
        output = "Click Encrypt or Decrypt";
        stepDesc = "No operation selected.";
        updateStats(msg, shift, "Ready");
      }
      if (currentMode) animateOutput(output);
      else document.getElementById('outputResult').innerHTML = output;
      document.getElementById('stepByStepArea').innerHTML = stepDesc;
      lastMessage = msg;
      lastShift = shift;
    }

    // Event listeners
    document.getElementById('encryptBtn').addEventListener('click', () => {
      currentMode = 'encrypt';
      refreshToolBasedOnMode();
      showNotification("Encryption applied! ✅", "success");
    });
    document.getElementById('decryptBtn').addEventListener('click', () => {
      currentMode = 'decrypt';
      refreshToolBasedOnMode();
      showNotification("Decryption applied! 🔓", "success");
    });
    document.getElementById('clearBtn').addEventListener('click', () => {
      document.getElementById('messageInput').value = "";
      document.getElementById('outputResult').innerHTML = "Cleared. Ready for new message.";
      document.getElementById('stepByStepArea').innerHTML = "Cleared. Type new message and choose encrypt/decrypt.";
      currentMode = null;
      updateStats("", parseInt(document.getElementById('shiftValue').value), "Cleared");
      showNotification("All fields cleared.", "info");
    });
    document.getElementById('copyResultBtn').addEventListener('click', () => {
      let resultText = document.getElementById('outputResult').innerText;
      if (!resultText || resultText.includes("output will appear")) {
        showNotification("Nothing to copy!", "error");
        return;
      }
      navigator.clipboard.writeText(resultText);
      showNotification("Copied to clipboard! 📋", "success");
    });
    document.getElementById('downloadTxtBtn').addEventListener('click', () => {
      let content = document.getElementById('outputResult').innerText;
      if (!content || content === "Your output will appear here...") {
        showNotification("No result to download.", "error");
        return;
      }
      let blob = new Blob([content], {type: "text/plain"});
      let a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = "caesar_cipher_result.txt";
      a.click();
      URL.revokeObjectURL(a.href);
      showNotification("Downloaded as TXT file 📁", "success");
    });
    document.getElementById('randomShiftBtn').addEventListener('click', () => {
      let rand = Math.floor(Math.random() * 25) + 1;
      document.getElementById('shiftValue').value = rand;
      refreshToolBasedOnMode();
      showNotification(`Random shift: ${rand} generated! 🎲`, "info");
    });
    document.getElementById('messageInput').addEventListener('input', () => {
      if(currentMode) refreshToolBasedOnMode();
      else { 
        let shift = parseInt(document.getElementById('shiftValue').value);
        updateStats(document.getElementById('messageInput').value, shift, "Ready");
      }
    });
    document.getElementById('shiftValue').addEventListener('input', () => {
      let val = parseInt(document.getElementById('shiftValue').value);
      if(isNaN(val)) val=3;
      val = Math.min(25, Math.max(1, val));
      document.getElementById('shiftValue').value = val;
      updateAlphabetVisual(val);
      if(currentMode) refreshToolBasedOnMode();
      else if(document.getElementById('messageInput').value) refreshToolBasedOnMode();
    });

    function showNotification(msg, type) {
      let notif = document.createElement('div');
      notif.className = `fixed top-5 left-1/2 transform -translate-x-1/2 z-50 px-6 py-2 rounded-full text-white font-semibold shadow-xl transition-all duration-300 ${type === 'success' ? 'bg-green-600' : type === 'error' ? 'bg-red-600' : 'bg-cyan-700'} animate-bounce`;
      notif.innerText = msg;
      document.body.appendChild(notif);
      setTimeout(() => { notif.remove(); }, 2200);
    }

    // Dark/Light Mode toggle
    const darkToggle = document.getElementById('darkModeToggle');
    darkToggle.addEventListener('click', () => {
      document.body.classList.toggle('dark');
      if (document.body.classList.contains('dark')) {
        document.body.style.background = "radial-gradient(circle at 20% 30%, #010205, #000000)";
        darkToggle.innerHTML = '<i class="fas fa-sun text-yellow-300"></i>';
      } else {
        document.body.style.background = "radial-gradient(circle at 20% 30%, #0a0f1e, #03050b)";
        darkToggle.innerHTML = '<i class="fas fa-moon text-cyan-300"></i>';
      }
    });

    // Floating binary generator
    function generateBinary() {
      const bgDiv = document.getElementById('binaryBg');
      setInterval(() => {
        let span = document.createElement('div');
        span.className = 'binary-float';
        let binarySeq = Math.random() > 0.5 ? '010110' : '101001';
        span.innerText = binarySeq + (Math.random() > 0.6 ? '101' : '011');
        span.style.left = Math.random() * 100 + '%';
        span.style.animationDuration = 12 + Math.random() * 20 + 's';
        span.style.fontSize = 0.8 + Math.random() * 1.5 + 'rem';
        span.style.opacity = 0.1 + Math.random() * 0.2;
        bgDiv.appendChild(span);
        setTimeout(() => { span.remove(); }, 20000);
      }, 1800);
    }
    generateBinary();

    // Scroll animations (fade-up)
    const faders = document.querySelectorAll('.fade-up');
    const appearOptions = { threshold: 0.2 };
    const appearOnScroll = new IntersectionObserver((entries, obs) => {
      entries.forEach(entry => {
        if(!entry.isIntersecting) return;
        entry.target.classList.add('appear');
        obs.unobserve(entry.target);
      });
    }, appearOptions);
    faders.forEach(f => appearOnScroll.observe(f));

    // Try now scroll to tool
    document.getElementById('tryNowBtn').addEventListener('click', () => {
      document.getElementById('tool').scrollIntoView({ behavior: 'smooth' });
    });

    // Reset all initial viz
    updateAlphabetVisual(3);
    document.getElementById('shiftValue').value = 3;
    // realtime preview (encrypt preview but shows on any change)
    window.refreshToolBasedOnMode = refreshToolBasedOnMode;
  </script>
</body>
</html>
