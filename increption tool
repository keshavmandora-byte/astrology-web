          <div>
            <label class="block text-sm font-semibold mb-2">📝 Your Message</label>
            <textarea id="messageInput" rows="4" class="w-full bg-black/40 border border-gray-600 rounded-xl p-3 text-white focus:border-cyan-400 outline-none resize-none" placeholder="Type or paste a message... (supports A-Z, a-z, spaces, symbols)"></textarea>
