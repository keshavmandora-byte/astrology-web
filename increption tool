    <!-- Statistics Dashboard & Learning Section Mix-->
    <div class="grid md:grid-cols-2 gap-8 fade-up my-12">
      <!-- Stats -->
      <div class="glass-card p-6">
        <h3 class="text-2xl font-bold flex items-center gap-2"><i class="fas fa-chart-simple text-cyan-400"></i> Statistics Dashboard</h3>
        <div class="mt-4 space-y-3">
          <div class="stat-card p-3 flex justify-between"><span>📊 Total Characters:</span><span id="statChars" class="font-bold">0</span></div>
          <div class="stat-card p-3 flex justify-between"><span>🔤 Letters Processed:</span><span id="statLetters" class="font-bold">0</span></div>
          <div class="stat-card p-3 flex justify-between"><span>⚙️ Current Shift:</span><span id="statShift" class="font-bold text-cyan-300">3</span></div>
          <div class="stat-card p-3 flex justify-between"><span>🔒 Encryption Status:</span><span id="statStatus" class="font-bold text-green-400">Ready</span></div>
        </div>
      </div>
      <!-- Learning Section Cards -->
      <div class="glass-card p-6">
        <h3 class="text-2xl font-bold flex items-center gap-2"><i class="fas fa-graduation-cap"></i> Cryptography Basics</h3>
        <div class="grid grid-cols-2 gap-3 mt-4">
          <div class="bg-black/30 p-3 rounded-xl text-center"><i class="fas fa-lock text-cyan-400 text-xl"></i><p class="font-semibold mt-1">Encryption</p><p class="text-xs">Plaintext → Ciphertext</p></div>
          <div class="bg-black/30 p-3 rounded-xl text-center"><i class="fas fa-key text-green-400 text-xl"></i><p class="font-semibold mt-1">Decryption</p><p class="text-xs">Ciphertext → Plaintext</p></div>
          <div class="bg-black/30 p-3 rounded-xl text-center"><i class="fas fa-sync-alt text-purple-400 text-xl"></i><p class="font-semibold mt-1">Symmetric</p><p class="text-xs">Same key for both</p></div>
          <div class="bg-black/30 p-3 rounded-xl text-center"><i class="fas fa-scroll text-amber-400 text-xl"></i><p class="font-semibold mt-1">Classical Ciphers</p><p class="text-xs">Historical roots</p></div>
        </div>
      </div>
