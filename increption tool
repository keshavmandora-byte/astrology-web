              <span class="text-cyan-300">Plain: </span>ABCDEFGHIJKLMNOPQRSTUVWXYZ<br>
              <span class="text-green-300">Shifted: </span><span id="visualShiftRow" class="font-bold">DEFGHIJKLMNOPQRSTUVWXYZABC</span>
