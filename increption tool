        </div>

        <!-- Cipher Visualization Section: Alphabet Wheel -->
        <div class="mt-10 bg-black/30 p-4 rounded-xl">
          <h3 class="text-xl font-semibold flex items-center gap-2"><i class="fas fa-chart-simple text-cyan-400"></i> Alphabet Shift Visualization</h3>
          <div class="grid md:grid-cols-2 gap-4 mt-3 text-center">
            <div><span class="text-gray-400">Original:</span> <span class="font-mono text-cyan-300 text-lg tracking-wider" id="origAlpha">ABCDEFGHIJKLMNOPQRSTUVWXYZ</span></div>
            <div><span class="text-gray-400">Shifted by <span id="shiftDisplayVal">3</span>:</span> <span class="font-mono text-green-300 text-lg tracking-wider" id="shiftedAlpha">DEFGHIJKLMNOPQRSTUVWXYZABC</span></div>
          </div>
          <div class="mt-2 text-xs text-center text-gray-400" id="alphabetHighlightHelper">Example: A → <span id="exampleMap">D</span></div>
