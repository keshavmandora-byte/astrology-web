<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>CyberGuard Elite | Password Strength Vault</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Inter', 'Poppins', 'Segoe UI', system-ui, sans-serif;
    }

    body {
      min-height: 100vh;
      background: #0a0c15;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      position: relative;
      overflow-x: hidden;
    }

    /* ========== ANIMATED BACKGROUND LAYERS ========== */
    .cyber-bg {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 0;
      overflow: hidden;
    }

    /* gradient mesh */
    .bg-gradient-1 {
      position: absolute;
      width: 100%;
      height: 100%;
      background: radial-gradient(circle at 20% 30%, #0f172f, #020617);
    }

    /* animated glowing orbs */
    .orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(60px);
      opacity: 0.5;
      animation: floatOrb 18s infinite alternate ease-in-out;
    }
    .orb1 { width: 400px; height: 400px; background: #3b00ff40; top: -100px; left: -150px; }
    .orb2 { width: 500px; height: 500px; background: #00e0ff30; bottom: -200px; right: -150px; animation-duration: 22s; }
    .orb3 { width: 300px; height: 300px; background: #ff2d7580; top: 40%; left: 60%; animation-duration: 14s; filter: blur(70px); }
    .orb4 { width: 250px; height: 250px; background: #00ffcc40; bottom: 10%; left: 5%; animation-duration: 19s; }

    @keyframes floatOrb {
      0% { transform: translate(0, 0) scale(1); }
      100% { transform: translate(60px, 80px) scale(1.2); }
    }

    /* grid overlay */
    .grid-overlay {
      position: absolute;
      width: 100%;
      height: 100%;
      background-image: 
        linear-gradient(rgba(0, 255, 255, 0.08) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0, 255, 255, 0.08) 1px, transparent 1px);
      background-size: 45px 45px;
      pointer-events: none;
    }

    /* animated particles + circuit lines */
    #circuitCanvas {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 1;
    }

    /* floating security icons */
    .floating-icons {
      position: absolute;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 1;
    }
    .float-icon {
      position: absolute;
      font-size: 1.8rem;
      opacity: 0.2;
      animation: floatIcon 20s infinite linear;
      filter: drop-shadow(0 0 5px cyan);
    }
    @keyframes floatIcon {
      0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
      10% { opacity: 0.3; }
      90% { opacity: 0.3; }
      100% { transform: translateY(-20vh) rotate(360deg); opacity: 0; }
    }

    /* main glass card - enhanced */
    .glass-card {
      position: relative;
      z-index: 20;
      max-width: 1350px;
      width: 100%;
      background: rgba(8, 18, 34, 0.65);
      backdrop-filter: blur(16px);
      border-radius: 2.8rem;
      border: 1px solid rgba(0, 255, 255, 0.35);
      box-shadow: 0 30px 55px rgba(0, 0, 0, 0.6), 0 0 28px rgba(0, 255, 255, 0.3);
      padding: 2rem 2rem 2.5rem;
      transition: all 0.4s ease;
    }

    @media (max-width: 780px) {
      .glass-card { padding: 1.2rem; }
    }

    .header {
      text-align: center;
      margin-bottom: 2rem;
    }

    .lock-icon {
      display: inline-flex;
      justify-content: center;
      align-items: center;
      background: linear-gradient(145deg, #00e0ff30, #0066ff40);
      padding: 0.9rem;
      border-radius: 4rem;
      margin-bottom: 1rem;
      animation: pulseGlow 2s infinite, floatLock 4s ease-in-out infinite;
      box-shadow: 0 0 20px cyan;
    }
    @keyframes pulseGlow {
      0% { box-shadow: 0 0 5px cyan; }
      50% { box-shadow: 0 0 25px #0ff; }
      100% { box-shadow: 0 0 5px cyan; }
    }
    @keyframes floatLock {
      0%,100% { transform: translateY(0px); }
      50% { transform: translateY(-8px); }
    }

    h1 {
      font-size: 2.4rem;
      background: linear-gradient(135deg, #FFFFFF, #7df9ff, #4effb5);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      letter-spacing: -0.5px;
      font-weight: 800;
    }

    .dashboard {
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
    }
    .left-col { flex: 1.4; min-width: 260px; }
    .right-col { flex: 2; min-width: 280px; }

    .input-group {
      background: rgba(0, 20, 40, 0.7);
      border-radius: 2rem;
      padding: 1.2rem 1.5rem;
      border: 1px solid #0ff55a80;
      transition: 0.2s;
    }
    .password-wrapper {
      display: flex;
      align-items: center;
      background: #010a1ae0;
      border-radius: 3rem;
      border: 1px solid #2c7f9e;
      padding: 0.2rem 0.2rem 0.2rem 1.4rem;
      transition: all 0.2s;
    }
    .password-wrapper:focus-within {
      border-color: #0ff;
      box-shadow: 0 0 14px #0ff8;
      transform: scale(1.01);
    }
    #passwordInput {
      flex: 1;
      background: transparent;
      border: none;
      padding: 1rem 0;
      font-size: 1.1rem;
      color: #f0fcff;
      outline: none;
      font-weight: 500;
    }
    .toggle-pw, .copy-btn, .gen-btn {
      background: none;
      border: none;
      cursor: pointer;
      font-size: 1.4rem;
      padding: 0.6rem;
      border-radius: 2rem;
      transition: 0.2s;
      color: #4cc9f0;
    }
    .toggle-pw:hover, .copy-btn:hover, .gen-btn:hover {
      background: #0ff22a20;
      transform: scale(1.08);
      color: #0ff;
      text-shadow: 0 0 5px cyan;
    }
    .action-buttons {
      display: flex;
      gap: 0.7rem;
      margin-top: 1rem;
    }
    .gradient-btn {
      background: linear-gradient(105deg, #00c6ff, #2b00ff);
      border: none;
      padding: 0.7rem 1.2rem;
      border-radius: 2rem;
      font-weight: 600;
      color: white;
      cursor: pointer;
      transition: all 0.25s;
      box-shadow: 0 4px 12px #0072ff60;
      flex: 1;
      font-size: 0.9rem;
    }
    .gradient-btn:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 24px #00a6ffb3;
      letter-spacing: 0.7px;
    }

    .strength-section {
      margin: 1.8rem 0;
    }
    .meter-bar {
      background: #111c2ce0;
      border-radius: 24px;
      height: 14px;
      overflow: hidden;
      box-shadow: inset 0 1px 5px #00000099;
    }
    .meter-fill {
      width: 0%;
      height: 100%;
      transition: width 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.2);
      border-radius: 24px;
      background: linear-gradient(90deg, #ff3366, #ffaa33, #33ffaa, #0ff);
      box-shadow: 0 0 6px #0ff;
    }
    .strength-text {
      font-size: 1.4rem;
      font-weight: bold;
      text-shadow: 0 0 5px currentColor;
    }
    .suggestions-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem;
      margin: 1rem 0;
    }
    .suggestion-badge {
      background: #0a102ccc;
      padding: 0.5rem 1rem;
      border-radius: 40px;
      font-size: 0.8rem;
      font-weight: 500;
      backdrop-filter: blur(4px);
      transition: 0.1s;
    }
    .badge-ok {
      border-left: 4px solid #0f0;
      background: #0f3b2fa0;
      color: #c8ffd0;
    }
    .badge-missing {
      border-left: 4px solid #ff8866;
      background: #2c1a1aa0;
      color: #ffcfbf;
    }
    .analysis-details {
      background: rgba(0, 0, 0, 0.55);
      border-radius: 1.8rem;
      padding: 1.2rem;
      backdrop-filter: blur(5px);
      border: 1px solid cyan20;
    }
    .detail-item {
      display: flex;
      justify-content: space-between;
      border-bottom: 1px solid #2c6f8f80;
      padding: 0.7rem 0;
      font-weight: 500;
    }
    .safety-tips {
      margin-top: 2rem;
      background: rgba(0, 25, 45, 0.7);
      border-radius: 1.6rem;
      padding: 1.2rem;
      border-right: 3px solid cyan;
    }
    .loading-spinner {
      display: inline-block;
      width: 18px;
      height: 18px;
      border: 2px solid #0ff;
      border-radius: 50%;
      border-top-color: transparent;
      animation: spin 0.6s linear infinite;
      margin-left: 12px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    @media (max-width: 640px) {
      h1 { font-size: 1.6rem; }
      .gradient-btn { font-size: 0.7rem; padding: 0.5rem; }
    }
    button:active { transform: scale(0.96); }
    .glow-effect { transition: all 0.2s; }
  </style>
</head>
<body>

<div class="cyber-bg">
  <div class="bg-gradient-1"></div>
  <div class="orb orb1"></div>
  <div class="orb orb2"></div>
  <div class="orb orb3"></div>
  <div class="orb orb4"></div>
  <div class="grid-overlay"></div>
  <canvas id="circuitCanvas"></canvas>
  <div class="floating-icons" id="floatingIconsContainer"></div>
</div>

<div class="glass-card">
  <div class="header">
    <div class="lock-icon">
      <svg width="52" height="52" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M17 11V7C17 4.79 15.21 3 13 3H11C8.79 3 7 4.79 7 7V11H5V19H19V11H17ZM11 5H13C14.1 5 15 5.9 15 7V11H9V7C9 5.9 9.9 5 11 5Z" fill="#0ff" fill-opacity="0.95"/>
        <path d="M12 16C10.9 16 10 15.1 10 14C10 12.9 10.9 12 12 12C13.1 12 14 12.9 14 14C14 15.1 13.1 16 12 16Z" fill="#0ff"/>
      </svg>
    </div>
    <h1>NOVA SECURE | PASSWORD ANALYZER</h1>
    <div class="sub" style="color:#9dc9ff;">Quantum strength metrics · realtime armor</div>
  </div>

  <div class="dashboard">
    <div class="left-col">
      <div class="input-group">
        <div class="password-wrapper">
          <input type="password" id="passwordInput" placeholder="Enter secret passphrase...">
          <button class="toggle-pw" id="togglePasswordBtn">👁️</button>
        </div>
        <div class="action-buttons">
          <button class="gradient-btn" id="generateBtn">✨ Generate Quantum Key</button>
          <button class="gradient-btn" id="copyPasswordBtn">📋 Copy Secure</button>
        </div>
      </div>

      <div class="strength-section">
        <div class="strength-label" style="display: flex; justify-content: space-between;">
          <span>🛡️ STRENGTH METER</span>
          <span id="strengthLevelText" class="strength-text" style="font-size:1.2rem;">Weak</span>
        </div>
        <div class="meter-bar">
          <div class="meter-fill" id="strengthMeterFill"></div>
        </div>
        <div id="strengthMsg" style="margin-top: 0.8rem;"></div>
      </div>

      <div class="safety-tips">
        <div class="tips-title" style="display: flex; gap:8px;">🔐 CYBER TIPS</div>
        <ul style="margin-left: 1.2rem; font-size:0.8rem;">
          <li>✔️ Use unique passwords per account</li>
          <li>✔️ Enable 2FA everywhere possible</li>
          <li>✔️ Avoid common words & sequences</li>
          <li>✔️ Consider a password manager</li>
        </ul>
      </div>
    </div>

    <div class="right-col">
      <div style="background: rgba(0,20,32,0.5); border-radius: 1.8rem; padding: 1.3rem;">
        <h3 style="display: flex; gap: 8px;">💡 IMPROVEMENT ENGINE <span id="loadingAnim" style="display:none;"><div class="loading-spinner"></div></span></h3>
        <div id="suggestionsList" class="suggestions-grid"></div>
      </div>
      <div class="analysis-details">
        <div class="detail-item"><span>📏 Length</span><span id="lengthVal">0</span></div>
        <div class="detail-item"><span>🎭 Character diversity</span><span id="varietyVal">—</span></div>
        <div class="detail-item"><span>⚡ Security index</span><span id="securityLevel">—</span></div>
        <div class="detail-item"><span>⏱️ Brute-force crack time</span><span id="crackTime">—</span></div>
      </div>
      <div style="margin-top: 1.2rem; text-align: center; font-size:0.7rem; background: #00000040; border-radius: 2rem; padding: 0.4rem;">🛡️ AES-inspired entropy analysis</div>
    </div>
  </div>
  <div class="footer-note" style="text-align:center; font-size:0.7rem; margin-top: 1.8rem;">⚡ Zero-Knowledge architecture | Local analysis only</div>
</div>

<script>
  // DOM elements
  const passwordInput = document.getElementById('passwordInput');
  const toggleBtn = document.getElementById('togglePasswordBtn');
  const generateBtn = document.getElementById('generateBtn');
  const copyBtn = document.getElementById('copyPasswordBtn');
  const meterFill = document.getElementById('strengthMeterFill');
  const strengthLevelSpan = document.getElementById('strengthLevelText');
  const strengthMsgDiv = document.getElementById('strengthMsg');
  const suggestionsContainer = document.getElementById('suggestionsList');
  const lengthSpan = document.getElementById('lengthVal');
  const varietySpan = document.getElementById('varietyVal');
  const securitySpan = document.getElementById('securityLevel');
  const crackTimeSpan = document.getElementById('crackTime');
  const loadingAnim = document.getElementById('loadingAnim');

  let audioCtx = null;
  function playSecureBeep(level) {
    if (level === 'Strong' || level === 'Very Strong') {
      try {
        if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.type = 'sine';
        osc.frequency.value = level === 'Strong' ? 880 : 1318;
        gain.gain.value = 0.12;
        osc.start();
        gain.gain.exponentialRampToValueAtTime(0.00001, audioCtx.currentTime + 0.45);
        osc.stop(audioCtx.currentTime + 0.45);
        if (audioCtx.state === 'suspended') audioCtx.resume();
      } catch(e) {}
    }
  }

  function getVarietyDesc(pwd) {
    let u = /[A-Z]/.test(pwd), l = /[a-z]/.test(pwd), d = /\d/.test(pwd), s = /[^A-Za-z0-9]/.test(pwd);
    let cnt = [u,l,d,s].filter(Boolean).length;
    if(cnt===4) return "Ultimate (4 types)";
    if(cnt===3) return "High (3 types)";
    if(cnt===2) return "Medium (2 types)";
    if(cnt===1) return "Low (1 type)";
    return "None";
  }

  function estimateCrackTime(pwd) {
    let len = pwd.length;
    if(len===0) return "—";
    let cs = 0;
    if(/[a-z]/.test(pwd)) cs+=26;
    if(/[A-Z]/.test(pwd)) cs+=26;
    if(/\d/.test(pwd)) cs+=10;
    if(/[^A-Za-z0-9]/.test(pwd)) cs+=33;
    if(cs===0) cs=1;
    let entropy = len * Math.log2(cs);
    let seconds = Math.pow(2, entropy) / 2e9; // 2 billion guesses/sec
    if(seconds < 1) return "< 1 second";
    if(seconds < 60) return Math.floor(seconds)+" sec";
    if(seconds < 3600) return Math.floor(seconds/60)+" min";
    if(seconds < 86400) return Math.floor(seconds/3600)+" hours";
    if(seconds < 31536000) return Math.floor(seconds/86400)+" days";
    if(seconds < 1e10) return Math.floor(seconds/31536000)+" years";
    return "Millennia 🔒";
  }

  function analyzePassword() {
    const pwd = passwordInput.value;
    loadingAnim.style.display = "inline-block";
    setTimeout(()=> { if(loadingAnim) loadingAnim.style.display = "none"; }, 200);

    let len = pwd.length;
    lengthSpan.innerText = len;
    let hasUpper = /[A-Z]/.test(pwd), hasLower = /[a-z]/.test(pwd), hasNumber = /\d/.test(pwd), hasSpecial = /[^A-Za-z0-9]/.test(pwd);
    let score = 0;
    if(len>=8) score++;
    if(len>=12) score++;
    if(len>=16) score++;
    if(hasUpper) score++;
    if(hasLower) score++;
    if(hasNumber) score++;
    if(hasSpecial) score+=2;
    if(hasUpper && hasLower && hasNumber && hasSpecial && len>=12) score+=2;
    if(len>=20) score++;
    
    let strength = "Weak";
    let percent = 0;
    if(len===0) strength = "None";
    else if(score<=2) strength = "Weak";
    else if(score<=4) strength = "Medium";
    else if(score<=6) strength = "Strong";
    else strength = "Very Strong";

    if(len===0) percent=0;
    else if(strength==="Weak") percent=25;
    else if(strength==="Medium") percent=52;
    else if(strength==="Strong") percent=78;
    else percent=100;
    
    meterFill.style.width = `${percent}%`;
    strengthLevelSpan.innerText = strength;
    let grad = strength==="Weak"?"#ff4d4d":strength==="Medium"?"#ffaa33":strength==="Strong"?"#33cc99":"#00ffcc";
    meterFill.style.background = `linear-gradient(90deg, ${grad}, #aaffff)`;
    strengthMsgDiv.innerHTML = strength==="Weak"?"🔻 High risk - improve immediately":strength==="Medium"?"⚠️ Moderate - add more variety":strength==="Strong"?"✅ Strong - well protected":"🏆 IMPENETRABLE!";

    varietySpan.innerText = getVarietyDesc(pwd);
    securitySpan.innerText = strength==="Weak"?"Critical":strength==="Medium"?"Fair":strength==="Strong"?"High":"Maximum";
    crackTimeSpan.innerText = estimateCrackTime(pwd);
    
    // suggestions list
    let missing = [];
    if(!hasUpper) missing.push("Add uppercase letters (A-Z)");
    if(!hasLower) missing.push("Add lowercase letters (a-z)");
    if(!hasNumber) missing.push("Add numbers (0-9)");
    if(!hasSpecial) missing.push("Add special chars (!@#$%^&*)");
    if(len < 8) missing.push("Increase length (minimum 8)");
    else if(len<12 && strength!=="Very Strong") missing.push("Use 12+ characters for best");
    if(missing.length===0) missing.push("✓ Flawless! Perfect entropy");

    suggestionsContainer.innerHTML = "";
    missing.forEach(sug => {
      const isOk = sug.includes("✓");
      const div = document.createElement('div');
      div.className = `suggestion-badge ${isOk ? 'badge-ok' : 'badge-missing'}`;
      div.innerHTML = isOk ? `✅ ${sug}` : `⚠️ ${sug}`;
      suggestionsContainer.appendChild(div);
    });
    
    if(strength === "Strong" || strength === "Very Strong") playSecureBeep(strength);
  }
  
  let deb;
  function handleInputReal() {
    clearTimeout(deb);
    deb = setTimeout(() => analyzePassword(), 60);
  }
  passwordInput.addEventListener('input', handleInputReal);
  
  toggleBtn.addEventListener('click', () => {
    let type = passwordInput.type === 'password' ? 'text' : 'password';
    passwordInput.type = type;
    toggleBtn.innerHTML = type === 'password' ? '👁️' : '🙈';
  });
  
  function generateQuantumPassword() {
    const upper = "ABCDEFGHJKLMNPQRSTUVWXYZ";
    const lower = "abcdefghijkmnopqrstuvwxyz";
    const digits = "0123456789";
    const special = "!@#$%^&*_+-=?.>";
    let arr = [];
    arr.push(upper[Math.floor(Math.random()*upper.length)]);
    arr.push(lower[Math.floor(Math.random()*lower.length)]);
    arr.push(digits[Math.floor(Math.random()*digits.length)]);
    arr.push(special[Math.floor(Math.random()*special.length)]);
    let fullSet = upper+lower+digits+special;
    let pwdLen = 16 + Math.floor(Math.random() * 6);
    for(let i=arr.length; i<pwdLen; i++) arr.push(fullSet[Math.floor(Math.random()*fullSet.length)]);
    for(let i=arr.length-1; i>0; i--) { let j=Math.floor(Math.random()*(i+1)); [arr[i], arr[j]] = [arr[j], arr[i]]; }
    return arr.join('');
  }
  
  generateBtn.addEventListener('click', () => {
    let newPwd = generateQuantumPassword();
    passwordInput.value = newPwd;
    analyzePassword();
  });
  
  copyBtn.addEventListener('click', async () => {
    let pwd = passwordInput.value;
    if(!pwd) { alert("No password to copy"); return; }
    try {
      await navigator.clipboard.writeText(pwd);
      let old = copyBtn.innerHTML;
      copyBtn.iSnnerHTML = "✅ Copied!";
      setTimeout(()=> copyBtn.innerHTML = old, 1200);
    } catch(e) { alert("Copy manually"); }
  });
  
  // ADVANCED BACKGROUND: circuit canvas + floating icons
  const canvas = document.getElementById('circuitCanvas');
  const ctxCanvas = canvas.getContext('2d');
  function resizeCanvasBg() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  window.addEventListener('resize', resizeCanvasBg);
  resizeCanvasBg();
  
  let nodes = [];
  for(let i=0;i<55;i++) {
    nodes.push({x: Math.random()*canvas.width, y: Math.random()*canvas.height, vx: (Math.random()-0.5)*0.3, vy: (Math.random()-0.5)*0.2});
  }
  function drawCircuit() {
    if(!ctxCanvas) return;
    ctxCanvas.clearRect(0,0,canvas.width,canvas.height);
    ctxCanvas.strokeStyle = "rgba(0, 210, 255, 0.25)";
    ctxCanvas.lineWidth = 1;
    for(let i=0;i<nodes.length;i++) {
      nodes[i].x += nodes[i].vx;
      nodes[i].y += nodes[i].vy;
      if(nodes[i].x<0) nodes[i].x=canvas.width;
      if(nodes[i].x>canvas.width) nodes[i].x=0;
      if(nodes[i].y<0) nodes[i].y=canvas.height;
      if(nodes[i].y>canvas.height) nodes[i].y=0;
      ctxCanvas.beginPath();
      ctxCanvas.arc(nodes[i].x, nodes[i].y, 1.8, 0, Math.PI*2);
      ctxCanvas.fillStyle = "#0ffaa0";
      ctxCanvas.fill();
      for(let j=i+1;j<nodes.length;j++) {
        let dx = nodes[i].x - nodes[j].x, dy = nodes[i].y - nodes[j].y;
        let dist = Math.hypot(dx,dy);
        if(dist < 120) {
          ctxCanvas.beginPath();
          ctxCanvas.moveTo(nodes[i].x, nodes[i].y);
          ctxCanvas.lineTo(nodes[j].x, nodes[j].y);
          ctxCanvas.stroke();
        }
      }
    }
    requestAnimationFrame(drawCircuit);
  }
  drawCircuit();
  
  // floating security icons generator
  const iconsContainer = document.getElementById('floatingIconsContainer');
  const iconsList = ['🔒', '🛡️', '⚡', '🔐', '💻', '🕵️', '🔑', '✨'];
  for(let i=0;i<35;i++) {
    let span = document.createElement('div');
    span.className = 'float-icon';
    span.innerHTML = iconsList[Math.floor(Math.random()*iconsList.length)];
    let size = 1 + Math.random() * 2;
    span.style.fontSize = `${size}rem`;
    span.style.left = `${Math.random() * 100}%`;
    span.style.animationDuration = `${12 + Math.random() * 25}s`;
    span.style.animationDelay = `${Math.random() * 15}s`;
    span.style.opacity = 0.15 + Math.random() * 0.2;
    iconsContainer.appendChild(span);
  }
  
  analyzePassword();
</script>
</body>
